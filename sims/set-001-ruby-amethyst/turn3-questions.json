{
  "description": "T3 play frequency and win rate impact, Singer/Song combo execution, and finisher usage. Covers all 4 T3 options (Maleficent, Friends, Aladdin, Magic Broom), the Maleficent→Friends singer line, and Dragon/Be Prepared closer comparison.",

  "definitions": {

    "mal_played_t3":     { "type": "card_played_by", "card": "maleficent-sorceress",        "turn": 3, "player": "me" },
    "friends_played_t3": { "type": "card_played_by", "card": "friends-on-the-other-side",   "turn": 3, "player": "me" },
    "aladdin_played_t3": { "type": "card_played_by", "card": "aladdin-street-rat",          "turn": 3, "player": "me" },
    "broom_played_t3":   { "type": "card_played_by", "card": "magic-broom-bucket-brigade",  "turn": 3, "player": "me" },

    "any_3drop_t3": {
      "type": "or",
      "conditions": [
        { "type": "ref", "name": "mal_played_t3" },
        { "type": "ref", "name": "friends_played_t3" },
        { "type": "ref", "name": "aladdin_played_t3" },
        { "type": "ref", "name": "broom_played_t3" }
      ]
    },

    "mal_in_play_t4":   { "type": "card_in_play_on",  "card": "maleficent-sorceress",       "turn": 4, "player": "me" },
    "dragon_played_t7": { "type": "card_played_by",   "card": "maleficent-monstrous-dragon", "turn": 7, "player": "me" },
    "beprepared_t7":    { "type": "card_played_by",   "card": "be-prepared",                 "turn": 7, "player": "me" },
    "elsa_played_t6":   { "type": "card_played_by",   "card": "elsa-spirit-of-winter",       "turn": 6, "player": "me" }

  },

  "queries": [

    {
      "name": "Games won",
      "condition": { "type": "won" }
    },

    {
      "name": "--- T3 PLAYS: frequency and win rate impact ---",
      "condition": { "type": "won" }
    },

    {
      "name": "Any 3-drop played on turn 3",
      "condition": { "type": "ref", "name": "any_3drop_t3" }
    },

    {
      "name": "Magic Broom played on T3",
      "condition": { "type": "ref", "name": "broom_played_t3" }
    },

    {
      "name": "Aladdin - Street Rat played on T3",
      "condition": { "type": "ref", "name": "aladdin_played_t3" }
    },

    {
      "name": "Friends on the Other Side played on T3",
      "condition": { "type": "ref", "name": "friends_played_t3" }
    },

    {
      "name": "Maleficent - Sorceress played on T3",
      "condition": { "type": "ref", "name": "mal_played_t3" }
    },

    {
      "name": "--- SINGER/SONG ANALYSIS ---",
      "condition": { "type": "won" }
    },

    {
      "name": "Maleficent still on board T4 (can sing Friends for free)",
      "condition": { "type": "ref", "name": "mal_in_play_t4" }
    },

    {
      "name": "Singer combo: Maleficent T3 + Friends played any turn",
      "condition": {
        "type": "and",
        "conditions": [
          { "type": "ref", "name": "mal_played_t3" },
          { "type": "not", "condition": { "type": "card_never_played", "card": "friends-on-the-other-side", "player": "me" } }
        ]
      }
    },

    {
      "name": "Friends T3 directly (paid ink, skipped Maleficent)",
      "condition": {
        "type": "and",
        "conditions": [
          { "type": "ref", "name": "friends_played_t3" },
          { "type": "not", "condition": { "type": "ref", "name": "mal_played_t3" } }
        ]
      }
    },

    {
      "name": "--- FINISHERS ---",
      "condition": { "type": "won" }
    },

    {
      "name": "Monstrous Dragon played by T7",
      "condition": { "type": "ref", "name": "dragon_played_t7" }
    },

    {
      "name": "Be Prepared played by T7",
      "condition": { "type": "ref", "name": "beprepared_t7" }
    },

    {
      "name": "Elsa - Spirit of Winter played by T6",
      "condition": { "type": "ref", "name": "elsa_played_t6" }
    },

    {
      "name": "Dragon AND Be Prepared both played (full finisher package)",
      "condition": {
        "type": "and",
        "conditions": [
          { "type": "ref", "name": "dragon_played_t7" },
          { "type": "ref", "name": "beprepared_t7" }
        ]
      }
    },

    {
      "name": "Neither Dragon nor Be Prepared played",
      "condition": {
        "type": "and",
        "conditions": [
          { "type": "card_never_played", "card": "maleficent-monstrous-dragon", "player": "me" },
          { "type": "card_never_played", "card": "be-prepared",                 "player": "me" }
        ]
      }
    }

  ]
}
