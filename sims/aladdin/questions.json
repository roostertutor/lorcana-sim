{
  "description": "Does the Aladdin combo line work? Tracks the Street Rat → Heroic Outlaw shift: does setup happen on time, does Outlaw hit the board by T5, and can you still win if you fall behind on lore?",
  "queries": [
    {
      "name": "Line A setup: Street Rat by turn 3, 5 ink by turn 5",
      "condition": {
        "type": "and",
        "conditions": [
          { "type": "card_played_by", "card": "aladdin-street-rat", "turn": 3, "player": "me" },
          { "type": "ink_gte", "amount": 5, "on_turn": 5, "player": "me" }
        ]
      }
    },
    {
      "name": "Line A fires: Street Rat alive on turn 5 (in play, not banished)",
      "condition": {
        "type": "and",
        "conditions": [
          { "type": "card_played_by", "card": "aladdin-street-rat", "turn": 3, "player": "me" },
          { "type": "card_in_play_on", "card": "aladdin-street-rat", "turn": 5, "player": "me" },
          { "type": "ink_gte", "amount": 5, "on_turn": 5, "player": "me" }
        ]
      }
    },
    {
      "name": "Heroic Outlaw hits board by turn 5",
      "condition": {
        "type": "card_played_by",
        "card": "aladdin-heroic-outlaw",
        "turn": 5,
        "player": "me"
      }
    },
    {
      "name": "Heroic Outlaw hits board by turn 6 (one turn late)",
      "condition": {
        "type": "card_played_by",
        "card": "aladdin-heroic-outlaw",
        "turn": 6,
        "player": "me"
      }
    },
    {
      "name": "Line C trap: forced to play Street Rat turn 4 not turn 3",
      "condition": {
        "type": "and",
        "conditions": [
          { "type": "card_played_by", "card": "aladdin-street-rat", "turn": 4, "player": "me" },
          {
            "type": "not",
            "condition": { "type": "card_played_by", "card": "aladdin-street-rat", "turn": 3, "player": "me" }
          }
        ]
      }
    },
    {
      "name": "Win rate when Heroic Outlaw is in play by turn 5",
      "condition": {
        "type": "and",
        "conditions": [
          { "type": "won", "player": "me" },
          { "type": "card_in_play_on", "card": "aladdin-heroic-outlaw", "turn": 5, "player": "me" }
        ]
      }
    },
    {
      "name": "Win rate when Heroic Outlaw never hits board",
      "condition": {
        "type": "and",
        "conditions": [
          { "type": "won", "player": "me" },
          { "type": "card_never_played", "card": "aladdin-heroic-outlaw", "player": "me" }
        ]
      }
    },
    {
      "name": "Behind on lore turn 5 (opponent at 8+ lore)",
      "condition": {
        "type": "lore_gte",
        "amount": 8,
        "by_turn": 5,
        "player": "opponent"
      }
    },
    {
      "name": "Behind on lore turn 5 BUT Heroic Outlaw in play",
      "condition": {
        "type": "and",
        "conditions": [
          { "type": "lore_gte", "amount": 8, "by_turn": 5, "player": "opponent" },
          { "type": "card_in_play_on", "card": "aladdin-heroic-outlaw", "turn": 5, "player": "me" }
        ]
      }
    },
    {
      "name": "The comeback: behind turn 5, win anyway",
      "condition": {
        "type": "and",
        "conditions": [
          { "type": "lore_gte", "amount": 8, "by_turn": 5, "player": "opponent" },
          { "type": "card_in_play_on", "card": "aladdin-heroic-outlaw", "turn": 5, "player": "me" },
          { "type": "won", "player": "me" }
        ]
      }
    }
  ]
}
