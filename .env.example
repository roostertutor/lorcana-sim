# Repo-root .env — script-facing env vars.
# Loaded by scripts/lib/image-sync.ts (and future scripts) via dotenv.
# Server env vars (SUPABASE_URL, etc.) live in server/.env, separate from this.
#
# Copy this file to `.env` and fill in real values. `.env` is gitignored.

# ── R2 (Cloudflare) — card-image self-hosting ────────────────────────────────
# Provisioning steps in docs/HANDOFF.md → "self-host card images on R2".
# Required for `pnpm sync-images-rav` / `sync-images-lorcast` / `sync-images-manual`
# to actually upload. Without these, those scripts auto-fallback to --dry-run.

# Your Cloudflare account ID. Should be a bare 32-char hex string like
# `7a8f9e...`. NOT the full endpoint URL.
# To find it: R2 dashboard → click a bucket → "API" tab → copy the
# hex portion of the "S3 API endpoint" URL
# (https://<account-id>.r2.cloudflarestorage.com → just the account-id).
# Pasting the full URL is tolerated — the script strips protocol + suffix.
R2_ACCOUNT_ID=

# R2 API token credentials — create at Dashboard → R2 → Manage R2 API Tokens.
# Permissions: Object Read & Write. Scope: lorcana-cards bucket only.
#
# IMPORTANT: use the S3-compatible credentials, NOT the cfat_-prefixed
# Cloudflare bearer token that Cloudflare shows first. After clicking
# "Create API Token" at the R2 tokens page, the result has THREE blocks:
#   1. "Your API Token" (cfat_...) — for api.cloudflare.com, NOT R2 S3. Ignore.
#   2. "Use bucket with S3 APIs" → "Access Key ID"    — this one
#   3. "Use bucket with S3 APIs" → "Secret Access Key" — this one (shown ONCE)
# If all you see is the cfat_ bearer, scroll down — the S3 creds block
# is below. If still not visible, you landed on the generic Account API
# Tokens page instead of R2's (R2 → Manage R2 API Tokens has the dual-cred
# result page).
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=

# Bucket name — scripts default to reading this but fall back to "lorcana-cards"
# if you use the conventional name.
R2_BUCKET=lorcana-cards

# Public base URL for card images. Two options:
#   - Custom domain (recommended for prod):  https://cards.yourdomain.com
#   - R2 default public URL (dev / testing): https://pub-<hash>.r2.dev
# The card JSON's `imageUrl` fields get rewritten to point here.
R2_PUBLIC_BASE_URL=
