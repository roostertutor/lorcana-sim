{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "composite": false,
    "declaration": false,
    "declarationMap": false,
    "noEmit": true,
    "jsx": "react-jsx",
    "types": ["vite/client"],
    "paths": {
      "@lorcana-sim/engine": ["../engine/src/index.ts"],
      "@lorcana-sim/simulator": ["../simulator/src/index.ts"],
      "@lorcana-sim/analytics": ["../analytics/src/index.ts"]
    }
  },
  "include": ["src/**/*"],
  "exclude": ["dist", "node_modules"]
}
